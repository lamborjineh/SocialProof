# ── Database — Neon (PostgreSQL, free tier) ───────────────────────────────────
# Sign up at neon.tech → New Project → Region: Asia Pacific (Singapore)
# Connection string format: postgresql+psycopg2://user:pass@host/dbname?sslmode=require
# NOTE: config.py auto-converts postgres:// → postgresql+psycopg2://
DATABASE_URL=postgresql+psycopg2://user:password@host.neon.tech/neondb?sslmode=require

# ── Auth ──────────────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-long-random-string-minimum-32-chars
JWT_EXPIRE_DAYS=7

# ── CORS — Set to your Vercel frontend URL ────────────────────────────────────
CORS_ORIGINS=https://your-app.vercel.app,http://localhost:5500

# ── ML Models (optional overrides) ───────────────────────────────────────────
# NLI_MODEL=MoritzLaurer/mDeBERTa-v3-base-mnli-xnli
# EMBED_MODEL=all-MiniLM-L6-v2

# ── External APIs ─────────────────────────────────────────────────────────────
GOOGLE_FACTCHECK_API_KEY=your-google-api-key
CLAIMBUSTER_API_KEY=your-claimbuster-key

# ── Ollama (not available on Railway — rule-based fallback will activate) ─────
# OLLAMA_URL=http://localhost:11434/api/generate
